rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profile document rules
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    
    // Username registration registry
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update: if false; // Usernames should be deleted and recreated, not updated directly
    }

    // User-specific progress tracker
    match /user_progress/{docId} {
      allow read, write: if request.auth != null && (
        (resource == null && request.resource.data.uid == request.auth.uid) ||
        (resource != null && resource.data.uid == request.auth.uid)
      );
    }

    // User-specific notes
    match /user_notes/{docId} {
      allow read, write: if request.auth != null && (
        (resource == null && request.resource.data.uid == request.auth.uid) ||
        (resource != null && resource.data.uid == request.auth.uid)
      );
    }

    // User-specific scheduled revisions
    match /user_revisions/{docId} {
      allow read, write: if request.auth != null && (
        (resource == null && request.resource.data.uid == request.auth.uid) ||
        (resource != null && resource.data.uid == request.auth.uid)
      );
    }

    // User-specific custom questions
    match /custom_questions/{docId} {
      allow read, write: if request.auth != null && (
        (resource == null && request.resource.data.uid == request.auth.uid) ||
        (resource != null && resource.data.uid == request.auth.uid)
      );
    }
  }
}
